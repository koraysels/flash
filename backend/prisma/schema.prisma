generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Direction {
  AB
  BA
}

model Camera {
  id                String    @id @default(cuid())
  name              String    @db.VarChar(255)
  location          String    @db.VarChar(255)
  streamUrl         String    @db.VarChar(1024)
  active            Boolean   @default(true)
  maxSpeedKmh       Int?
  homographyMatrix  Float[]
  calibrationPoints Json?
  countingLineA     Float     @default(0.4)
  countingLineB     Float     @default(0.6)
  countingLineAPoints Float[] // [x1,y1,x2,y2] normalised 0-1; overrides countingLineA if length==4
  countingLineBPoints Float[] // same for line B
  trapSpeedEnabled    Boolean  @default(false)
  trackingConfig      Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  trafficEvents     TrafficEvent[]
  dailyCounts       DailyCount[]
}

model TrafficEvent {
  id           String    @id @default(cuid())
  cameraId     String
  camera       Camera    @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  timestamp    DateTime  @default(now())
  direction    Direction
  vehicleClass String    @db.VarChar(50)
  speedKmh     Float?
  isSpeeder    Boolean   @default(false)

  @@index([cameraId, timestamp])
}

model DailyCount {
  id           String   @id @default(cuid())
  cameraId     String
  camera       Camera   @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  date         DateTime
  directionAB  Int      @default(0)
  directionBA  Int      @default(0)
  speeders     Int      @default(0)

  @@unique([cameraId, date])
}
